generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  emailVerified     Boolean        @default(false)
  verificationToken String?
  username          String?
  avatarUrl         String?
  signature         String?
  role              Role           @default(USER)
  reputation        Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  status            String         @default("ACTIVE")
  password          String?
  provider          String?
  providerId        String?
  phoneNumber       String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  bookmarks         Bookmark[]
  follows           Follow[]
  likes             Like[]
  receivedNotes     Notification[] @relation("NoteReceiver")
  sentNotes         Notification[] @relation("NoteSender")
  posts             Post[]
  reports           Report[]
  shareTasks        ShareTask[]
  threads           Thread[]
  badges            UserBadge[]
  wallet            Wallet?
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  status      String   @default("ACTIVE")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  boards      Board[]
}

model Board {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  status      String   @default("ACTIVE")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  threads     Thread[]
}

model Thread {
  id         String      @id @default(uuid())
  title      String
  content    String
  slug       String      @unique
  views      Int         @default(0)
  isPinned   Boolean     @default(false)
  isLocked   Boolean     @default(false)
  isFeatured Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  boardId    String
  authorId   String
  analytics  Analytics[]
  bookmarks  Bookmark[]
  likes      Like[]
  posts      Post[]
  reports    Report[]
  shareTasks ShareTask[]
  author     User        @relation(fields: [authorId], references: [id])
  board      Board       @relation(fields: [boardId], references: [id])
  tags       Tag[]       @relation("ThreadTags")
}

model Post {
  id        String   @id @default(uuid())
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  threadId  String
  authorId  String
  likes     Like[]
  author    User     @relation(fields: [authorId], references: [id])
  thread    Thread   @relation(fields: [threadId], references: [id])
  reports   Report[]
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  threads   Thread[] @relation("ThreadTags")
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  threadId  String?
  postId    String?
  createdAt DateTime @default(now())
  post      Post?    @relation(fields: [postId], references: [id])
  thread    Thread?  @relation(fields: [threadId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, threadId])
  @@unique([userId, postId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, threadId])
}

model Notification {
  id         String   @id @default(uuid())
  receiverId String
  senderId   String?
  type       String
  content    String
  link       String?
  metadata   Json?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("NoteReceiver", fields: [receiverId], references: [id])
  sender     User?    @relation("NoteSender", fields: [senderId], references: [id])
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  iconUrl     String?
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  grantedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, badgeId])
}

model Follow {
  id         String   @id @default(uuid())
  userId     String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  threadId   String?
  postId     String?
  reason     String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  post       Post?    @relation(fields: [postId], references: [id])
  reporter   User     @relation(fields: [reporterId], references: [id])
  thread     Thread?  @relation(fields: [threadId], references: [id])
}

model Analytics {
  id        String   @id @default(uuid())
  threadId  String
  eventType String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id])
}

model ShareTask {
  id           String          @id @default(uuid())
  sharedUrl    String
  status       ShareTaskStatus @default(PENDING)
  proofNote    String?
  rewardAmount Decimal         @db.Decimal(20, 2)
  approvedAt   DateTime?
  paymentDueAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  userId       String
  threadId     String
  thread       Thread          @relation(fields: [threadId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
}

model Wallet {
  id             String        @id @default(uuid())
  balance        Decimal       @default(0) @db.Decimal(20, 2)
  pendingBalance Decimal       @default(0) @db.Decimal(20, 2)
  updatedAt      DateTime      @updatedAt
  userId         String        @unique
  transactions   Transaction[]
  user           User          @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(20, 2)
  type        String
  status      String   @default("PENDING")
  description String?
  createdAt   DateTime @default(now())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum ShareTaskStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}
